{
  "name": "yt-keyword-crawler",
  "version": "1.0.0",
  "description": "Scheduled service that polls YouTube for a keyword, perceptually dedups thumbnails, and queues only new uploads.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "crawl:once": "ts-node src/cli-crawl.ts",
    "phash:demo": "ts-node src/cli-phash.ts",
    "test:dedup": "npm run build && node test/dedup-test.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "jimp": "^0.22.12",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
